# Neon PostgreSQL — 풀링 연결 (앱 런타임용)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Neon PostgreSQL — 다이렉트 연결 (prisma migrate용)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# NextAuth
AUTH_SECRET=your_auth_secret_here
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret
AUTH_KAKAO_ID=your_kakao_client_id
AUTH_KAKAO_SECRET=your_kakao_client_secret

# 온통청년 Open API
YOUTH_API_SERVICE_KEY=your_youth_api_key_here
