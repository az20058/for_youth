# Neon PostgreSQL — 풀링 연결 (앱 런타임용, PgBouncer 경유)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Neon PostgreSQL — 다이렉트 연결 (prisma migrate 등 CLI 명령용, PgBouncer 우회)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=false"
