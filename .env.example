# Neon PostgreSQL — 풀링 연결 (앱 런타임용)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Neon PostgreSQL — 다이렉트 연결 (prisma migrate용)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Anthropic API (기업 분석 AI 요약에 사용)
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth
AUTH_SECRET=your_auth_secret_here
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret
AUTH_KAKAO_ID=your_kakao_client_id
AUTH_KAKAO_SECRET=your_kakao_client_secret

# 온통청년 Open API
YOUTH_API_SERVICE_KEY=your_youth_api_key_here

# 공공데이터포털 (금융위원회 기업기본정보 API — 인코딩된 키)
DATA_GO_KR_API_KEY=your_encoded_api_key_here

# 네이버 검색 API
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 배치 Job 인증 (Vercel Cron 등에서 사용)
CRON_SECRET=your_cron_secret_here
