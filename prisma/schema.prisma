generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id           String            @id @default(cuid())
  companyName  String
  careerLevel  String
  deadline     DateTime?
  companySize  CompanySize
  status       ApplicationStatus @default(PENDING)
  url          String?
  coverLetters   CoverLetter[]
  scheduleEvents ScheduleEvent[]
  userId       String?
  user         User?             @relation(fields: [userId], references: [id])
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([deadline])
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  bio             String?
  school          String?
  major           String?
  careerLevel     String?
  portfolioUrl    String?
  resumeUrl       String?
  education       Json?
  careers         Json?
  certifications  Json?
  languages       Json?
  techStacks      Json?
  accounts       Account[]
  applications   Application[]
  scheduleEvents ScheduleEvent[]
  quizResults    UserQuizResult[]
  notifications  Notification[]
  createdAt      DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model UserQuizResult {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers         String   @db.Text
  recommendations String   @db.Text
  createdAt       DateTime @default(now())

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model CoverLetter {
  id            String           @id @default(cuid())
  question      String
  answer        String           @default("")
  type          CoverLetterType?
  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
}

enum ApplicationStatus {
  PENDING            // 지원 예정
  CODING_TEST        // 코테 기간
  INTERVIEW          // 면접 기간
  APPLIED            // 지원 완료
  ACCEPTED           // 최종 합격
  REJECTED_DOCS      // 서류 탈락
  REJECTED_CODING    // 코테 탈락
  REJECTED_INTERVIEW // 면접 탈락
}

enum CompanySize {
  LARGE     // 대기업
  MID_LARGE // 중견기업
  MID       // 중소기업
  STARTUP   // 스타트업
}

enum CoverLetterType {
  MOTIVATION   // 지원 동기
  GROWTH       // 성장 과정
  JOB_SKILLS   // 직무 역량
  PERSONALITY  // 성격 장단점
  SUCCESS      // 성공 경험
  FAILURE      // 실패 경험
  TEAMWORK     // 팀워크 경험
  FUTURE_GOALS // 입사 후 포부
  OTHER        // 기타
}

model ScheduleEvent {
  id            String            @id @default(cuid())
  title         String
  date          DateTime
  type          ScheduleEventType
  memo          String?
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application?      @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId])
}

enum ScheduleEventType {
  CODING_TEST // 코딩테스트
  INTERVIEW   // 면접
  DOCUMENT    // 서류 마감
  OTHER       // 기타
}

model CompanySummary {
  id              String   @id @default(cuid())
  companyName     String   @unique
  overview        String   @db.Text
  mainBusiness    String   @db.Text
  recentNews      String   @db.Text
  motivationHints String   @db.Text
  crawledAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model YouthPolicy {
  plcyNo        String   @id
  name          String
  agency        String
  mainCategory  String
  category      String
  description   String   @db.Text
  supportContent String? @db.Text
  applicationUrl String?
  viewCount     Int      @default(0)
  region        String?
  zipCodes      String?
  bizPrdEndYmd  String?
  syncedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([region])
  @@index([mainCategory])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  relatedId String?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

enum NotificationType {
  DEADLINE
  SCHEDULE
  STATUS_CHANGE
}
